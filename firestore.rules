rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper functions ---
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function incomingData() {
      return request.resource.data;
    }

    function existingData() {
      return resource.data;
    }

    function isValidString(field, maxLen) {
      return field is string && field.size() <= maxLen;
    }

    // Only these fields changed
    function onlyChanged(fields) {
      return incomingData().diff(existingData()).affectedKeys().hasOnly(fields);
    }

    // --- Users ---
    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId)
        && isValidString(incomingData().displayName, 50)
        && incomingData().followerCount == 0
        && incomingData().followingCount == 0;
      allow update: if isOwner(userId)
        && isValidString(incomingData().displayName, 50)
        && (!('bio' in incomingData()) || isValidString(incomingData().bio, 500))
        // Prevent self-manipulation of social counters
        && incomingData().followerCount == existingData().followerCount
        && incomingData().followingCount == existingData().followingCount;
    }

    // --- Posts ---
    match /posts/{postId} {
      allow read: if true;
      allow create: if isAuth()
        && incomingData().authorId == request.auth.uid
        && isValidString(incomingData().title, 200)
        && (!('body' in incomingData()) || isValidString(incomingData().body, 5000))
        && incomingData().type in ['note', 'quote', 'image', 'video']
        && incomingData().likeCount == 0
        && incomingData().saveCount == 0
        && incomingData().boardCount == 0;
      allow delete: if isOwner(existingData().authorId);
      // Author can update anything; others can only update counters
      allow update: if isAuth() && (
        isOwner(existingData().authorId)
          && incomingData().authorId == existingData().authorId
        ||
        onlyChanged(['likeCount', 'saveCount', 'boardCount'])
      );
    }

    // --- Likes ---
    match /likes/{likeId} {
      allow read: if true;
      allow create: if isAuth()
        && incomingData().userId == request.auth.uid;
      allow delete: if isOwner(existingData().userId);
    }

    // --- Saves ---
    match /saves/{saveId} {
      allow read: if isAuth();
      allow create: if isAuth()
        && incomingData().userId == request.auth.uid;
      allow delete: if isOwner(existingData().userId);
    }

    // --- Boards ---
    match /boards/{boardId} {
      allow read: if existingData().isPublic == true
        || isOwner(existingData().ownerId);
      allow create: if isAuth()
        && incomingData().ownerId == request.auth.uid
        && isValidString(incomingData().name, 100)
        && (!('description' in incomingData()) || isValidString(incomingData().description, 500))
        && incomingData().likeCount == 0
        && incomingData().followerCount == 0;
      allow update: if isOwner(existingData().ownerId)
        && incomingData().ownerId == existingData().ownerId;
      allow delete: if isOwner(existingData().ownerId);
    }

    // --- Board Items ---
    match /boardItems/{itemId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow delete: if isAuth();
    }

    // --- Board Likes ---
    match /boardLikes/{likeId} {
      allow read: if true;
      allow create: if isAuth()
        && incomingData().userId == request.auth.uid;
      allow delete: if isOwner(existingData().userId);
    }

    // --- Board Follows ---
    match /boardFollows/{followId} {
      allow read: if true;
      allow create: if isAuth()
        && incomingData().userId == request.auth.uid;
      allow delete: if isOwner(existingData().userId);
    }

    // --- User Follows ---
    match /userFollows/{followId} {
      allow read: if true;
      allow create: if isAuth()
        && incomingData().userId == request.auth.uid
        && incomingData().followedUserId != request.auth.uid;
      allow delete: if isOwner(existingData().userId);
    }

    // --- Tags ---
    match /tags/{tagName} {
      allow read: if true;
      allow create, update: if isAuth()
        && isValidString(incomingData().name, 30);
    }
  }
}
